# 複製成 .env（本機開發用）；HF Spaces 改用 Space secrets 注入，勿 commit .env（已 gitignore）。
# 金鑰皆免信用卡：aistudio.google.com（Gemini）/ console.groq.com（Groq）。
GEMINI_API_KEY=
GROQ_API_KEY=

# 生成後端：ollama(預設,本機 qwen3:4b) | cloud(免費雲端 API)
# CITERAG_LLM_BACKEND=cloud

# 選配
# CITERAG_GEMINI_MODEL=gemini-2.5-flash-lite
# CITERAG_GROQ_MODEL=llama-3.1-8b-instant     # fallback 模型；繁中更佳可改 Groq 上的 qwen（自行確認 model id）
# CITERAG_CLOUD_TIMEOUT=60
# CITERAG_PGVECTOR=1                            # 改用 pgvector 向量後端（預設 FAISS）
