# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# --- 模型權重 / 快取（大檔；fastembed 首次使用會自動下載到 hf_cache，勿入庫）---
hf_cache/
models/

# --- 索引：commit 已建好的索引（HF 免費 build 記憶體無法 embed 9.6k chunks，故不在 build 時重建）---
#     faiss.index 走 LFS（見 .gitattributes）；其餘 index/ 衍生檔仍忽略
index/*
!index/chunks.jsonl
!index/faiss.index

# --- 祕密 / 環境變數 ---
.env
.env.*
!.env.example

# --- 作業系統 / 編輯器 ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- 本機開發守則 / 筆記（不入庫）---
CLAUDE.md

# --- 暫存 / 快取 ---
*.log
*.out
_tmp_*.py
_smoke_*.py
_t_*.py
.findata_cache.json
